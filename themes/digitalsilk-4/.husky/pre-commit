#!/bin/sh

# Check if phpcs is installed and recognized
if ! command -v phpcs >/dev/null 2>&1; then
    echo "Error: phpcs is not recognized. Please install it or check your PATH." >&2
    exit 0 # Allow the commit to proceed
fi

# Define the path to the directory
TARGET_DIR="wp-content/themes/digitalsilk"

# Navigate to the appropriate directory
if [ ! -d "$TARGET_DIR" ]; then
    echo "Warning: Target directory $TARGET_DIR does not exist. Skipping lint-staged checks." >&2
    exit 0 # Allow the commit to proceed
fi

cd "$TARGET_DIR" || {
    echo "Warning: Failed to navigate to $TARGET_DIR. Skipping lint-staged checks." >&2
    exit 0 # Allow the commit to proceed
}

# Run lint-staged to check staged files
if ! command -v npx >/dev/null 2>&1; then
    echo "Error: npx is not recognized. Please install Node.js and ensure npx is available." >&2
    exit 1 # Prevent the commit from happening as npx is critical
fi

npx lint-staged
