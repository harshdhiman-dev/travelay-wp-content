{
	"name": "dst",
	"version": "2.0.0",
	"author": "Digital Silk",
	"description": "Starter theme for Digital Silk projects.",
	"license": "MIT",
	"engines": {
		"node": ">=22.7.0"
	},
	"scripts": {
		"prepare": "cd ../../.. && husky wp-content/themes/digitalsilk/.husky",
		"watch": "run-p start:blocks dev",
		"dev": "vite",
		"build": "run-p build:assets build:blocks",
		"build:assets": "vite build",
		"clean:blocks": "rimraf build/react",
		"build:blocks": "npm run clean:blocks && wp-scripts build --webpack-src-dir=modules/gutenberg --output-path=build/react --experimental-modules",
		"start:blocks": "wp-scripts start --webpack-src-dir=modules/gutenberg --output-path=build/react --experimental-modules",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style --fix",
		"lint": "npm run lint:js && npm run lint:css",
		"create-block": "cd modules/gutenberg/blocks/custom && wp-create-block --no-plugin --template ../../../../bin/create-block-template"
	},
	"lint-staged": {
		"*.php": [
			"vendor/bin/phpcs --standard=.phpcs.xml.dist"
		],
		"*.scss": "npm run lint:css"
	},
	"devDependencies": {
		"@spiriit/vite-plugin-svg-spritemap": "^3.0.0",
		"@wordpress/create-block": "^4.60.0",
		"@wordpress/eslint-plugin": "^22.3.0",
		"@wordpress/icons": "^10.18.0",
		"@wordpress/scripts": "^30.10.0",
		"@wordpress/stylelint-config": "^23.9.0",
		"glob": "^11.0.1",
		"husky": "^9.1.7",
		"lint-staged": "^15.4.3",
		"npm-run-all": "^4.1.5",
		"rimraf": "^6.0.1",
		"sass": "^1.84.0",
		"vite": "^6.1.0",
		"vite-plugin-live-reload": "^3.0.4"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"classnames": "^2.5.1",
		"uuid": "^11.1.0"
	}
}
