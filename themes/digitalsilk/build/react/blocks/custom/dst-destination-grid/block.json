{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ds-blocks/destination-grid",
  "title": "DST Destination Grid",
  "category": "ds-layouts",
  "icon": "screenoptions",
  "description": "A bento-style image grid with bottom overlay labels and a decorated section heading. Great for 'Popular Cities', categories, or destination listings.",
  "example": {},
  "attributes": {
    "heading": {
      "type": "object",
      "default": {
        "title": "Popular Cities in the India",
        "showDecoration": true
      }
    },
    "items": {
      "type": "array",
      "default": [
        {
          "media": {
            "primaryType": "image",
            "imagePrimary": {
              "id": "",
              "url": "https://travelaystagging.com/wp-content/uploads/2026/06/Group-550.png",
              "alt": "Flights from Leh",
              "size": "full"
            }
          },
          "label": "Flights from Leh"
        },
        {
          "media": {
            "primaryType": "image",
            "imagePrimary": {
              "id": "",
              "url": "https://travelaystagging.com/wp-content/uploads/2026/06/Group-549.png",
              "alt": "Flights from Jaipur",
              "size": "full"
            }
          },
          "label": "Flights from Jaipur"
        },
        {
          "media": {
            "primaryType": "image",
            "imagePrimary": {
              "id": "",
              "url": "https://travelaystagging.com/wp-content/uploads/2026/06/Group-548.png",
              "alt": "Flights from Mumbai",
              "size": "full"
            }
          },
          "label": "Flights from Mumbai"
        },
        {
          "media": {
            "primaryType": "image",
            "imagePrimary": {
              "id": "",
              "url": "https://travelaystagging.com/wp-content/uploads/2026/06/Group-547.png",
              "alt": "Flights from Goa",
              "size": "full"
            }
          },
          "label": "Flights from Goa"
        },
        {
          "media": {
            "primaryType": "image",
            "imagePrimary": {
              "id": "",
              "url": "https://travelaystagging.com/wp-content/uploads/2026/06/Group-546.png",
              "alt": "Flights from Delhi",
              "size": "full"
            }
          },
          "label": "Flights from Delhi"
        }
      ]
    },
    "background": {
      "type": "object",
      "default": {
        "type": "none",
        "color": "#1f7a4d",
        "image": {
          "id": "",
          "url": "",
          "alt": ""
        },
        "imageMobile": {
          "id": "",
          "url": "",
          "alt": ""
        },
        "mediaFit": "cover",
        "mediaPosition": "center center",
        "disableLazyLoad": false,
        "overlayOpacity": 0,
        "overlayColor": "#000000"
      }
    },
    "spacing": {
      "type": "object",
      "default": {
        "paddingTop": "",
        "paddingRight": "",
        "paddingBottom": "",
        "paddingLeft": "",
        "marginTop": "",
        "marginRight": "",
        "marginBottom": "",
        "marginLeft": ""
      }
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "dsGapControl": true
  },
  "textdomain": "dstheme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}