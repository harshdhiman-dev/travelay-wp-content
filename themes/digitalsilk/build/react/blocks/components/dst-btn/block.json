{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "ds-blocks/c-btn",
  "title": "DST Button",
  "category": "ds-components",
  "icon": "button",
  "description": "Advanced button component",
  "attributes": {
    "text": {
      "type": "string",
      "default": ""
    },
    "link": {
      "type": "object",
      "default": null
    },
    "btnType": {
      "type": "string",
      "default": "primary",
      "enum": [
        "primary",
        "secondary",
        "link",
        "primary-inverted",
        "primary-inverted-light",
        "secondary-inverted"
      ]
    },
    "btnSize": {
      "type": "string",
      "default": "default",
      "enum": [
        "small",
        "default",
        "large"
      ]
    },
    "iconType": {
      "type": "string",
      "default": "default",
      "enum": [
        "default",
        "custom",
        "none"
      ]
    },
    "hasIcon": {
      "type": "boolean",
      "default": false
    },
    "iconValue": {
      "type": "string",
      "default": ""
    },
    "iconRevesed": {
      "type": "boolean",
      "default": false
    },
    "iconPosition": {
      "type": "string",
      "default": "row",
      "enum": [
        "row",
        "row-reverse"
      ]
    },
    "hasPopup": {
      "type": "boolean",
      "default": false
    }
  },
  "example": {
    "attributes": {
      "text": "DigitalSilk Button ",
      "btnType": "primary",
      "btnSize": "large",
      "style": {
        "color": {
          "background": "var(--dst--btn-primary-bg)",
          "text": "var(--dst--btn-primary-color)"
        },
        "spacing": {
          "padding": {
            "top": "1.5em",
            "right": "1.5em",
            "bottom": "1.5em",
            "left": "1.5em"
          }
        },
        "border": {
          "radius": "12px"
        }
      }
    }
  },
  "supports": {
    "html": false,
    "innerBlocks": true,
    "color": {
      "background": false,
      "gradients": false,
      "text": false
    },
    "dsClassList": [
      {
        "name": "alex-is-awesome",
        "label": "Custom class 1"
      },
      {
        "name": "danny-change-me",
        "label": "Custom class 2"
      }
    ]
  },
  "styles": [
    {
      "name": "default",
      "label": "Default",
      "isDefault": true
    },
    {
      "name": "custom",
      "label": "Custom"
    }
  ],
  "textdomain": "dstheme",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php"
}