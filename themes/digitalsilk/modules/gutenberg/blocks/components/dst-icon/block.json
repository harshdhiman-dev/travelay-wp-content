{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "ds-blocks/c-icon",
	"title": "DST Icon",
	"category": "ds-components",
	"icon": "star-empty",
	"description": "Really simple icon block, where you can choose between built-in theme icons and user-uploaded icons",
	"attributes": {
		"anchor": {
			"type": "string",
			"default": ""
		},
		"icon": {
			"type": "string",
			"default": ""
		},
		"iconSet": {
			"type": "array",
			"default": [ "theme", "social", "buttons", "general"]
		},
		"size" : {
			"type": "integer",
			"default": 25
		},
		"placeholder" : {
			"type": "string",
			"default": "Select an icon"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"background": true,
			"text": true,
			"link": false
		}
	},
	"example": {
		"attributes": {
			"placeholder": "My Icon Goes Here",
			"size": 250,
			"style": {
				"color": {
					"gradient": "linear-gradient(-97.8deg, #723fc7 30%, #5192f7 76.87%, #407cd9 100%)",
					"text": "#ffffff"
				},
				"spacing": {
					"padding": {
						"top": "2em",
						"right": "2em",
						"bottom": "2em",
						"left": "2em"
					}
				}
			}
		}
	},
	"textdomain": "dstheme",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
