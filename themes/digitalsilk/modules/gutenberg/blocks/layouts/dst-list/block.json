{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ds-blocks/c-list",
	"version": "1.0.0",
	"title": "DST List",
	"category": "ds-components",
	"icon": "",
	"description": "List component",
	"example": {},
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"gradients": true
		},
		"background": {
			"backgroundImage": true,
			"backgroundSize": true
		},
		"typography": {
			"textAlign": true
		},
		"dsEffects" : true,
		"dsGapControl": true,
		"dsContainers": true,
		"dsClassList" : [
			{
				"name": "change-class-name",
				"label": "Custom class 1"
			},
			{
				"name": "dont-worry-you-can-change-it",
				"label": "Custom class 2"
			},
			{
				"name": "--contact-menu-wrapper",
				"label": "Contact Menu Wrapper"
			},
			{
				"name": "--cards-list-v1",
				"label": "Cards List v1"
			},
			{
				"name": "--cards-list-v2",
				"label": "Cards List v2"
			}
		]
	},
	"attributes": {
		"anchor" : {
			"type": "string",
			"default" : ""
		},
		"showSubtitle": {
			"type": "boolean",
			"default": false
		},
		"showIcons": {
			"type": "boolean",
			"default": false
		},
		"showHeroText": {
			"type": "boolean",
			"default": false
		},
		"hasVerticalBorder": {
			"type": "boolean",
			"default": false
		},
		"hasHorizontalBorder": {
			"type": "boolean",
			"default": false
		},
		"gapBetween": {
			"type": "string",
			"default": "10px"
		},
		"colCount": {
			"type": "number",
			"default": 1
		},
		"alignment": {
			"type": "string",
			"default": "row"
		},
		"iconsSize": {
			"type": "string",
			"default": ""
		},
		"subtitleSize": {
			"type": "string",
			"default": ""
		},
		"heroTextSize": {
			"type": "string",
			"default": ""
		},
		"titleSize": {
			"type": "string",
			"default": ""
		},
		"titleTransform" : {
			"type": "string",
			"default": ""
		},
		"titleWeight" : {
			"type": "string",
			"default": ""
		},
		"titleLineHeight": {
			"type": "number",
			"default": 1.2
		},
		"colorHero" : {
			"type": "string",
			"default": ""
		},
		"colorSubtitle" : {
			"type": "string",
			"default": ""
		},
		"colorIcon" : {
			"type": "string",
			"default": ""
		},
		"colorTitle" : {
			"type": "string",
			"default": ""
		},
		"gapBetweenContent" : {
			"type": "string",
			"default": ""
		},
		"itemPadding": {
			"type": "object",
			"default": {
				"top": "0rem",
				"right": "0rem",
				"bottom": "0rem",
				"left": "0rem"
			}
		},
		"dsContainer": {
			"type": "string",
			"default": ""
		},
		"dsContainerSideGap": {
			"type": "boolean",
			"default": false
		},
 	"moduleVariant": {
 		"type": "string",
 		"default": ""
 	},
 	"iconAlignment": {
 		"type": "string",
 		"default": "flex-start"
 	}
	},
	"providesContext": {
		"ds-blocks/showSubtitle": "showSubtitle",
		"ds-blocks/showIcons": "showIcons",
		"ds-blocks/showHeroText": "showHeroText",
		"ds-blocks/alignment": "alignment"
	},
	"textdomain": "ds-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
