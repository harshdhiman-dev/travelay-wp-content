{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ds-blocks/c-card",
	"title": "DST Card (experimental)",
	"category": "widgets",
	"icon": "align-full-width",
	"description": "Advanced card component, with customizable heading, button, and styles.",
	"example": {},
	"attributes": {
		"media": {
			"type": "object",
			"default": {}
		},
		"heading": {
			"type": "object",
			"default": {
				"alignment": "left",
				"alignmentMobile": "left",
				"pretitle": "",
				"backtitle": "",
				"title_styles": {
					"tag": "h2",
					"tag_style": "h2",
					"color": ""
				},
				"title": "",
				"subtitle": "",
				"description": "",
				"pretitle_color": "",
				"subtitle_color": "",
				"showPretitle": true,
				"showTitle": true,
				"showSubtitle": false,
				"showDescription": true
			}
		},
		"button": {
			"type": "object",
			"default": {
				"text": "",
				"link": null,
				"btnType": "primary",
				"btnSize": "default",
				"iconType": "default",
				"hasIcon": false,
				"iconValue": "",
				"iconRevesed": false,
				"iconPosition": "row"
			}
		}
	},
	"supports": {
		"html": false
	},
	"textdomain": "dstheme",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
