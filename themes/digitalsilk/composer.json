{
    "name": "digitalsilk/dst",
    "description": "Starter theme for Digital Silk projects.",
    "version": "1.0.0",
    "type": "wordpress-theme",
    "homepage": "https://git.dsstaging1.com/projects/dst",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "vcs",
            "url": "ssh://git@gitea.dsstaging1.com:2222/wp-gutenberg/dst-phpcs.git"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "wp-gutenberg/dst-phpcs": "dev-master"
    },
    "scripts": {
        "phpcs": "./vendor/bin/phpcs .",
        "phpcbf": "./vendor/bin/phpcbf .",
        "build": [
            "rm -rf vendor",
            "composer install --no-dev --no-plugins -o"
        ],
        "ci": [
            "composer install",
            "composer phpcs",
            "rm -rf vendor",
            "composer install --no-dev --no-plugins -o"
        ]
    },
    "config": {
        "secure-http": false,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
