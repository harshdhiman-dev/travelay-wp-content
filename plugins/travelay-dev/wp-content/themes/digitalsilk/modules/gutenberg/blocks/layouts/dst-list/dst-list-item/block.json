{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ds-blocks/c-list-item",
	"version": "1.0.0",
	"title": "List Item",
	"category": "ds-content",
	"icon": "",
	"description": "List Item Component",
	"example": {},
	"supports": {
		"html": false,
		"splitting": true,
		"anchor": true,
		"dsClassList" : [
			{
				"name": "change-class-name-here",
				"label": "Custom class 1"
			},
			{
				"name": "dont-worry-you-can-change-it-nothing-is-using-this-class",
				"label": "Custom class 2"
			}
		]
	},
	"attributes": {
		"anchor": {
			"type": "string",
			"default": ""
		},
		"icon": {
			"type": "string",
			"default": ""
		},
		"iconSize": {
			"type": "string",
			"default": "100%"
		},
		"iconDisplay": {
			"type": "string",
			"default": "inline",
			"enum": ["inline", "img"]
		},
		"heroText": {
			"type": "string",
			"default": ""
		},
		"listTitle": {
			"type": "string",
			"default": ""
		},
		"listSubTitle": {
			"type": "string",
			"default": ""
		}
	},
	"usesContext" : [
        "ds-blocks/showSubtitle",
		"ds-blocks/showIcons",
		"ds-blocks/showHeroText"
    ],
    "styles": [
		{
			"name": "default",
			"label": "Default",
			"isDefault": true
		},
		{
			"name": "this-is-a-custom-class-that-can-be-styled-by-developers-you-can-also-name-it-whatever-you-want",
			"label": "Custom"
		}
	],
	"textdomain": "ds-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"parent": [
		"ds-blocks/c-list"
	]
}
