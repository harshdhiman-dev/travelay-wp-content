{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "ds-blocks/l-content-2",
	"title": "DST Content-2 (Gutenberg)",
	"category": "ds-hybrid",
	"icon": "align-pull-right",
	"description": "Flexible two-column block that lets you combine images, videos, and text side-by-side. You can swap sides, mix content types, and control alignment to create custom layouts with ease.",
	"example": {},
	"attributes": {
		"anchor": {
			"type": "string",
			"default": ""
		},
		"media": {
			"type": "object",
			"default": {}
		},
		"columnsOrder": {
			"type": "string",
			"default": "order-default",
			"enum": [
				"order-default",
				"order-reverse"
			]
		},
		"columnsGap": {
			"type": "string",
			"default": "20px"
		},
		"contentRatio": {
			"type": "integer",
			"default": 50
		},
		"isVertical": {
			"type": "boolean",
			"default": false
		},
		"textPaddingLeftDesktop": {
			"type": "string",
			"default": ""
		},
		"textPaddingLeftMobile": {
			"type": "string",
			"default": ""
		},
		"textPaddingRightDesktop": {
			"type": "string",
			"default": ""
		},
		"textPaddingRightMobile": {
			"type": "string",
			"default": ""
		},
		"textYAlign": {
			"type": "string",
			"default": "align-center",
			"enum": [
				"align-top",
				"align-center",
				"align-bottom"
			]
		},
		"mediaXAlign": {
			"type": "string",
			"default": "media-to-center",
			"enum": [
				"media-to-left",
				"media-to-center",
				"media-to-right"
			]
		},
		"mediaYAlign": {
			"type": "string",
			"default": "media-justify-center",
			"enum": [
				"media-justify-top",
				"media-justify-center",
				"media-justify-bottom"
			]
		},
		"columnsOrderMobile": {
			"type": "string",
			"default": "",
			"enum": [
				"order-default-mobile",
				"order-reverse-mobile",
				""
			]
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"background": {
			"backgroundImage": true,
			"backgroundSize": true
		},
		"color": {
			"background": true,
			"gradients": true,
			"text": false,
			"link": false
		},
		"dsGapControl": true,
		"dsContainers": true,
		"dsEffects": true,
		"dsClassList" : [
			{
				"name": "nemanja-hates-this",
				"label": "Custom class 1"
			},
			{
				"name": "volo-approves-this-class-name",
				"label": "Custom class 2"
			}
		]
	},
	"textdomain": "dstheme",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./markup.php"
}
