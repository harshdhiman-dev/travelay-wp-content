{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "ds-blocks/ds-column",
	"title": "DST Single Column",
	"category": "design",
	"parent": [
		"ds-blocks/ds-columns"
	],
	"description": "A single column within a columns block.",
	"example": {},
	"attributes": {
		"anchor": {
			"type": "string",
			"default": ""
		},
		"class": {
			"type": "string",
			"default": "ds-column"
		},
		"columnSpan": {
			"type": "number",
			"default": 6
		},
		"columnSpanTablet": {
			"type": "number",
			"default": 1
		},
		"columnMinHeight": {
			"type": "number",
			"default": 0
		},
		"columnMinHeightMobile": {
			"type": "number",
			"default": 0
		},
		"alignVertical": {
			"type": "string",
			"default": ""
		},
		"alignHorizontal": {
			"type": "string",
			"default": ""
		},
		"allowedBlocks": {
			"type": "array"
		},
		"templateLock": {
			"type": [
				"string",
				"boolean"
			],
			"enum": [
				"all",
				"insert",
				"contentOnly",
				false
			]
		}
	},
	"supports": {
		"__experimentalOnEnter": true,
		"anchor": true,
		"className": false,
		"reusable": false,
		"html": false,
		"background": {
			"backgroundImage": true,
			"backgroundSize": true
		},
		"color": {
			"background": true,
			"gradients": true,
			"text": false,
			"link": false
		},
		"position": {
			"sticky": true
		},
		"layout": false,
		"interactivity": {
			"clientNavigation": true
		}
	},
	"textdomain": "digitalsilk",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php"
}
